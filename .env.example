# ── Application ───────────────────────────────────────────────────────────────
APP_ENV=dev

# ── API ───────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true
API_DEBUG=false
API_TOKEN=your-api-token
CONTACT_EMAIL=chitrank2050@gmail.com

# ── LLM ───────────────────────────────────────────────────────────────────────
GROQ_API_KEY=your-groq-api-key
GROQ_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# ── Embeddings ────────────────────────────────────────────────────────────────
# EMBEDDING_PROVIDER: "voyage" (default) or "local" (all-MiniLM-L6-v2, no API needed)
# Switching providers requires re-embedding all chunks (different vector dimensions).
EMBEDDING_PROVIDER=voyage
VOYAGE_API_KEY=your-voyage-api-key
VOYAGE_MODEL=voyage-3-lite
EMBEDDING_DIMENSIONS=512

# ── Database ──────────────────────────────────────────────────────────────────
# Local development: point both URLs at your local PostgreSQL instance.
# DATABASE_URL must use the async driver (+asyncpg)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/askchitrank
# DATABASE_URL_SYNC must use the sync driver (+psycopg2)
DATABASE_URL_SYNC=postgresql+psycopg2://postgres:postgres@localhost:5432/askchitrank

# Production: use your hosted PostgreSQL / Supabase connection strings instead.
# Note: for PaaS deployments that need pooled IPv4 connections, use the Supabase
# pooler URL on port 6543 and append ?sslmode=require when needed.
SUPABASE_URL=https://[REF].supabase.co
SUPABASE_KEY=your-supabase-anon-key

# ── Sanity CMS ────────────────────────────────────────────────────────────────
SANITY_PROJECT_ID=your-project-id
SANITY_DATASET=production
SANITY_API_TOKEN=your-api-token
SANITY_API_VERSION=2024-01-01

# ── Cache ─────────────────────────────────────────────────────────────────────
CACHE_SIMILARITY_THRESHOLD=0.95
CACHE_TTL_DAYS=7

# ── Development Mode ─────────────────────────────────────────────────────────
DEV_MODE=false

# ── Headers to Expose ─────────────────────────────────────────────────────────
API_EXPOSE_HEADERS=["X-Response-Time", "X-Request-ID"]
