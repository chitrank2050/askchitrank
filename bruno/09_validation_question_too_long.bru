meta {
  name: 09 Validation — Question Too Long (expect 422)
  type: http
  seq: 9
}

docs {
  # Validation — Question Too Long

  Tests that Pydantic schema validation rejects questions over 500 characters.
  The `ChatRequest` schema enforces `max_length=500` on the question field.

  ## Expected Response
  **HTTP 422 Unprocessable Entity**
  ```json
  {
    "error": {
      "code": 422,
      "type": "VALIDATION_ERROR",
      "message": "Request validation failed: ...",
      "request_id": "abc12345"
    }
  }
  ```
}

post {
  url: {{baseUrl}}/v1/chat
  body: json
  auth: bearer
}

auth:bearer {
  token: {{apiToken}}
}

body:json {
  {
    "question": "This question is intentionally too long. Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed do eiusmod tempor incididunt ut labore et dolore magna aliqua. Ut enim ad minim veniam, quis nostrud exercitation ullamco laboris nisi ut aliquip ex ea commodo consequat. Duis aute irure dolor in reprehenderit in voluptate velit esse cillum dolore eu fugiat nulla pariatur. Excepteur sint occaecat cupidatat non proident, sunt in culpa qui officia deserunt mollit anim id est laborum padding padding padding.",
    "session_id": "{{sessionId}}",
    "stream": false
  }
}

tests {
  // ── Status code ──────────────────────────────────────────────────────────
  test("returns HTTP 422", function() {
    expect(res.status).to.equal(422);
  });

  // ── Error shape ───────────────────────────────────────────────────────────
  test("error.type is VALIDATION_ERROR", function() {
    expect(res.body.error.type).to.equal("VALIDATION_ERROR");
  });

  test("error.code is 422", function() {
    expect(res.body.error.code).to.equal(422);
  });
}
